\newcommand{\redactNaturalLabeled}[2]{\censorplus@redactlabeled{white!91!black}{#1}{#2}}
\newcommand{\redactRedLabeled}[2]{\censorplus@redactlabeled{red}{#1}{#2}}
\newcommand{\redactBlueLabeled}[2]{\censorplus@redactlabeled{blue}{#1}{#2}}
\newcommand{\redactGreenLabeled}[2]{\censorplus@redactlabeled{green!70!black}{#1}{#2}}
\newcommand{\redactBlackLabeled}[2]{\censorplus@redactlabeled{black}{#1}{#2}}
\newcommand{\redactWhiteLabeled}[2]{\censorplus@redactlabeled{white}{#1}{#2}}

\newcommand{\unredactNatural}[1]{\censorplus@unredact{white!91!black}{black}{#1}{Y}}
\newcommand{\unredactRed}[1]{\censorplus@unredact{red}{white}{#1}{N}}
\newcommand{\unredactBlue}[1]{\censorplus@unredact{blue}{white}{#1}{N}}
\newcommand{\unredactGreen}[1]{\censorplus@unredact{green!70!black}{white}{#1}{N}}
\newcommand{\unredactBlack}[1]{\censorplus@unredact{black}{white}{#1}{N}}
\newcommand{\unredactWhite}[1]{\censorplus@unredact{white}{black}{#1}{Y}}

% Helper macro to split text into words and apply unredactNatural to each word
\newcommand{\censorplus@unredactNaturalSplit}[1]{%
	\begingroup
		\def\censorplus@processword##1 {%
			\ifx##1\@empty\else
				\unredactNatural{##1}\space
			\fi}%
		\expandafter\censorplus@processwords#1 \@nil
	\endgroup}

\def\censorplus@processwords#1 #2\@nil{%
	\unredactNatural{#1}%
	\ifx#2\@empty\else
		\space\expandafter\censorplus@processwords#2\@nil
	\fi}

\newcommand{\unredactNaturalSplit}[1]{\censorplus@processwords#1 \@nil}

% Split versions for all unredaction flavors
\newcommand{\unredactRedSplit}[1]{\censorplus@processwordsRed#1 \@nil}
\newcommand{\unredactBlueSplit}[1]{\censorplus@processwordsBlue#1 \@nil}
\newcommand{\unredactGreenSplit}[1]{\censorplus@processwordsGreen#1 \@nil}
\newcommand{\unredactBlackSplit}[1]{\censorplus@processwordsBlack#1 \@nil}
\newcommand{\unredactWhiteSplit}[1]{\censorplus@processwordsWhite#1 \@nil}

