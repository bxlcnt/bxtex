\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{censorPlus}[2026/03/14 Censor/redaction helpers]

\RequirePackage{censor}
\RequirePackage{xcolor}
\RequirePackage{xstring}

\makeatletter

\def\censorplus@rulecolor{black}
\let\censorplus@basecensorrule\censorrule
\renewcommand\censorrule[1]{%
\textcolor{\censorplus@rulecolor}{\censorplus@basecensorrule{#1}}}

\newcommand{\censorplus@redact}[2]{%
	\begingroup
		\def\censorplus@rulecolor{#1}%
		\censor{#2}%
	\endgroup}

\newcommand{\censorplus@redactlabeled}[3]{%
	\begingroup
		\def\censorplus@rulecolor{#1}%
		\sbox0{\censor{#3}}%
		\makebox[0pt][l]{\usebox0}%
		\makebox[\wd0][c]{%
			\begingroup
				\setlength{\fboxsep}{1pt}%
				\setlength{\fboxrule}{0.3pt}%
				\fcolorbox{black}{white}{\textcolor{black}{{\tiny #2}}}%
			\endgroup}%
	\endgroup}

\newcommand{\censorplus@unredact}[4]{%
	\begingroup
		\def\censorplus@rulecolor{#1}%
		\sbox0{\censor{#3}}%
		\makebox[0pt][l]{\usebox0}%
		\makebox[\wd0][c]{%
			\ifx#4Y%
				\begingroup
					\setlength{\fboxsep}{1pt}%
					\setlength{\fboxrule}{0.3pt}%
					\fbox{\textcolor{#2}{#3}}%
				\endgroup
			\else
				\textcolor{#2}{#3}%
			\fi}%
	\endgroup}

% Qualifier mappings
\newcommand{\redactNatural}[1]{\censorplus@redact{white!91!black}{#1}}
\newcommand{\redactRed}[1]{\censorplus@redact{red}{#1}}
\newcommand{\redactBlue}[1]{\censorplus@redact{blue}{#1}}
\newcommand{\redactGreen}[1]{\censorplus@redact{green!70!black}{#1}}
\newcommand{\redactBlack}[1]{\censorplus@redact{black}{#1}}
\newcommand{\redactWhite}[1]{\censorplus@redact{white}{#1}}

% Split versions for plain redactions
\newcommand{\redactNaturalSplit}[1]{\censorplus@processRedactNatural#1 \@nil}
\newcommand{\redactRedSplit}[1]{\censorplus@processRedactRed#1 \@nil}
\newcommand{\redactBlueSplit}[1]{\censorplus@processRedactBlue#1 \@nil}
\newcommand{\redactGreenSplit}[1]{\censorplus@processRedactGreen#1 \@nil}
\newcommand{\redactBlackSplit}[1]{\censorplus@processRedactBlack#1 \@nil}
\newcommand{\redactWhiteSplit}[1]{\censorplus@processRedactWhite#1 \@nil}

% Word processing macros for redaction splits
\def\censorplus@processRedactNatural#1 #2\@nil{%
	\redactNatural{#1}%
	\ifx#2\@empty\else
		\space\expandafter\censorplus@processRedactNatural#2\@nil
	\fi}

